<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" th:replace="~{layout :: layout(titulo='Tickets', pagina='tickets', conteudo=~{::content})}">
    <head><link rel="stylesheet" href="/src/main/resources/static/css/styles.css"></head>
<div th:fragment="content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gerenciamento de Tickets</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalTicket">
            <i class="bi bi-plus-circle"></i> Novo Ticket
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <input type="text" class="form-control" id="searchTicket" placeholder="Buscar por assunto...">
                </div>
                <div class="col-md-3 mb-3">
                    <select class="form-select" id="filterPrioridade">
                        <option value="">Todas as Prioridades</option>
                        <option value="BAIXA">Baixa</option>
                        <option value="MEDIA">Média</option>
                        <option value="ALTA">Alta</option>
                        <option value="URGENTE">Urgente</option>
                    </select>
                </div>
                <div class="col-md-3 mb-3">
                    <select class="form-select" id="filterStatus">
                        <option value="">Todos os Status</option>
                        <option value="ABERTO">Aberto</option>
                        <option value="EM_ANDAMENTO">Em Andamento</option>
                        <option value="AGUARDANDO_CLIENTE">Aguardando Cliente</option>
                        <option value="RESOLVIDO">Resolvido</option>
                        <option value="FECHADO">Fechado</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3">
                    <button class="btn btn-secondary w-100" onclick="filtrarTickets()">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela de Tickets -->
    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Assunto</th>
                        <th>Prioridade</th>
                        <th>Status</th>
                        <th>Data Abertura</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="ticketsTableBody">
                    <tr th:each="ticket : ${tickets}">
                        <td th:text="${ticket.id}"></td>
                        <td>
                            <a th:href="@{/clientes}" th:text="${ticket.cliente != null ? ticket.cliente.nome : 'N/A'}"></a>
                        </td>
                        <td th:text="${ticket.assunto}"></td>
                        <td>
                            <span class="badge"
                                  th:classappend="${ticket.prioridade == 'URGENTE'} ? 'bg-danger' : (${ticket.prioridade == 'ALTA'} ? 'bg-warning' : (${ticket.prioridade == 'MEDIA'} ? 'bg-info' : 'bg-secondary'))"
                                  th:text="${ticket.prioridade}"></span>
                        </td>
                        <td>
                            <span class="badge"
                                  th:classappend="${ticket.status == 'ABERTO'} ? 'bg-danger' : (${ticket.status == 'EM_ANDAMENTO'} ? 'bg-warning' : (${ticket.status == 'RESOLVIDO'} ? 'bg-success' : 'bg-secondary'))"
                                  th:text="${ticket.status}"></span>
                        </td>
                        <td th:text="${#temporals.format(ticket.dataAbertura, 'dd/MM/yyyy HH:mm')}"></td>
                        <td>
                            <button class="btn btn-sm btn-info" th:onclick="'verTicket(' + ${ticket.id} + ')'" title="Visualizar">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning" th:onclick="'editarTicket(' + ${ticket.id} + ')'" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" th:onclick="'deletarTicket(' + ${ticket.id} + ')'" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Cadastrar/Editar Ticket -->
    <div class="modal fade" id="modalTicket" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Novo Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formTicket">
                        <input type="hidden" id="ticketId" name="id">
                        
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label class="form-label">Cliente *</label>
                                <select class="form-select" name="cliente.id" required>
                                    <option value="">Selecione um cliente</option>
                                    <!-- Carregar via AJAX -->
                                </select>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Assunto *</label>
                            <input type="text" class="form-control" name="assunto" required>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Descrição *</label>
                            <textarea class="form-control" name="descricao" rows="5" required></textarea>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Prioridade</label>
                                <select class="form-select" name="prioridade">
                                    <option value="BAIXA">Baixa</option>
                                    <option value="MEDIA" selected>Média</option>
                                    <option value="ALTA">Alta</option>
                                    <option value="URGENTE">Urgente</option>
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status</label>
                                <select class="form-select" name="status">
                                    <option value="ABERTO" selected>Aberto</option>
                                    <option value="EM_ANDAMENTO">Em Andamento</option>
                                    <option value="AGUARDANDO_CLIENTE">Aguardando Cliente</option>
                                    <option value="RESOLVIDO">Resolvido</option>
                                    <option value="FECHADO">Fechado</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="salvarTicket()">
                        <i class="bi bi-check-lg"></i> Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Visualizar Ticket -->
    <div class="modal fade" id="modalVerTicket" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Detalhes do Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="detalhesTicket">
                    <!-- Conteúdo carregado via JavaScript -->
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fechar</button>
                </div>
            </div>
        </div>
    </div>

    <script th:inline="javascript">
        /*<![CDATA[*/
        
        // Carregar clientes no select
        window.addEventListener('DOMContentLoaded', function() {
            fetch('/api/clientes')
            .then(response => response.json())
            .then(clientes => {
                const select = document.querySelector('[name="cliente.id"]');
                clientes.forEach(cliente => {
                    const option = document.createElement('option');
                    option.value = cliente.id;
                    option.textContent = cliente.nome;
                    select.appendChild(option);
                });
            });
        });

        function salvarTicket() {
            const form = document.getElementById('formTicket');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            
            // Converter cliente.id para objeto cliente
            if (data['cliente.id']) {
                data.cliente = { id: parseInt(data['cliente.id']) };
                delete data['cliente.id'];
            }
            
            if (!data.id) delete data.id;
            
            const method = data.id ? 'PUT' : 'POST';
            const url = data.id ? `/api/tickets/${data.id}` : '/api/tickets';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => {
                if (!response.ok) throw new Error('Erro ao salvar ticket');
                return response.json();
            })
            .then(() => {
                alert('Ticket salvo com sucesso!');
                location.reload();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao salvar ticket.');
            });
        }

        function deletarTicket(id) {
            if (confirm('Deseja realmente deletar este ticket?')) {
                fetch(`/api/tickets/${id}`, { method: 'DELETE' })
                .then(response => {
                    if (response.ok) {
                        alert('Ticket deletado com sucesso!');
                        location.reload();
                    } else {
                        throw new Error('Erro ao deletar ticket');
                    }
                })
                .catch(error => {
                    console.error('Erro:', error);
                    alert('Erro ao deletar ticket.');
                });
            }
        }

        function verTicket(id) {
            fetch(`/api/tickets/${id}`)
            .then(response => response.json())
            .then(ticket => {
                const clienteNome = ticket.cliente ? ticket.cliente.nome : 'N/A';
                const dataAbertura = new Date(ticket.dataAbertura).toLocaleString('pt-BR');
                
                const html = `
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>ID:</strong> ${ticket.id}
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>Cliente:</strong> ${clienteNome}
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <strong>Prioridade:</strong> 
                            <span class="badge bg-${ticket.prioridade == 'URGENTE' ? 'danger' : ticket.prioridade == 'ALTA' ? 'warning' : 'info'}">${ticket.prioridade}</span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <strong>Status:</strong> 
                            <span class="badge bg-${ticket.status == 'ABERTO' ? 'danger' : ticket.status == 'RESOLVIDO' ? 'success' : 'warning'}">${ticket.status}</span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <strong>Assunto:</strong> ${ticket.assunto}
                    </div>
                    <div class="mb-3">
                        <strong>Descrição:</strong>
                        <p class="mt-2">${ticket.descricao}</p>
                    </div>
                    <div class="mb-3">
                        <strong>Data de Abertura:</strong> ${dataAbertura}
                    </div>
                `;
                
                document.getElementById('detalhesTicket').innerHTML = html;
                const modal = new bootstrap.Modal(document.getElementById('modalVerTicket'));
                modal.show();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao buscar ticket.');
            });
        }

        function editarTicket(id) {
            fetch(`/api/tickets/${id}`)
            .then(response => response.json())
            .then(ticket => {
                document.querySelector('[name="id"]').value = ticket.id;
                document.querySelector('[name="cliente.id"]').value = ticket.cliente ? ticket.cliente.id : '';
                document.querySelector('[name="assunto"]').value = ticket.assunto;
                document.querySelector('[name="descricao"]').value = ticket.descricao;
                document.querySelector('[name="prioridade"]').value = ticket.prioridade;
                document.querySelector('[name="status"]').value = ticket.status;
                
                document.querySelector('.modal-title').textContent = 'Editar Ticket';
                
                const modal = new bootstrap.Modal(document.getElementById('modalTicket'));
                modal.show();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao buscar ticket.');
            });
        }

        function filtrarTickets() {
            const searchTerm = document.getElementById('searchTicket').value.toLowerCase();
            const prioridadeFilter = document.getElementById('filterPrioridade').value;
            const statusFilter = document.getElementById('filterStatus').value;
            const rows = document.querySelectorAll('#ticketsTableBody tr');
            
            rows.forEach(row => {
                const assunto = row.cells[2].textContent.toLowerCase();
                const prioridade = row.querySelector('td:nth-child(4) .badge').textContent.trim();
                const status = row.querySelector('td:nth-child(5) .badge').textContent.trim();
                
                const matchesSearch = assunto.includes(searchTerm);
                const matchesPrioridade = !prioridadeFilter || prioridade === prioridadeFilter;
                const matchesStatus = !statusFilter || status === statusFilter;
                
                if (matchesSearch && matchesPrioridade && matchesStatus) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        document.getElementById('searchTicket').addEventListener('input', filtrarTickets);
        document.getElementById('filterPrioridade').addEventListener('change', filtrarTickets);
        document.getElementById('filterStatus').addEventListener('change', filtrarTickets);

        document.getElementById('modalTicket').addEventListener('hidden.bs.modal', function () {
            document.getElementById('formTicket').reset();
            document.querySelector('.modal-title').textContent = 'Novo Ticket';
            document.querySelector('[name="id"]').value = '';
        });
        
        /*]]>*/
    </script>
</div>
</html>