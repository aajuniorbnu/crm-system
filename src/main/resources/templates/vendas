<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org" th:replace="~{layout :: layout(titulo='Vendas', pagina='vendas', conteudo=~{::content})}">

<head><link rel="stylesheet" href="/src/main/resources/static/css/styles.css"></head>
<div th:fragment="content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Gerenciamento de Vendas</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalVenda">
            <i class="bi bi-plus-circle"></i> Nova Venda
        </button>
    </div>

    <!-- Filtros -->
    <div class="card mb-4">
        <div class="card-body">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <input type="date" class="form-control" id="dataInicio" placeholder="Data Início">
                </div>
                <div class="col-md-4 mb-3">
                    <input type="date" class="form-control" id="dataFim" placeholder="Data Fim">
                </div>
                <div class="col-md-2 mb-3">
                    <select class="form-select" id="filterStatus">
                        <option value="">Todos os Status</option>
                        <option value="PENDENTE">Pendente</option>
                        <option value="APROVADA">Aprovada</option>
                        <option value="CANCELADA">Cancelada</option>
                        <option value="ENTREGUE">Entregue</option>
                    </select>
                </div>
                <div class="col-md-2 mb-3">
                    <button class="btn btn-secondary w-100" onclick="filtrarVendas()">
                        <i class="bi bi-funnel"></i> Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Tabela de Vendas -->
    <div class="card">
        <div class="card-body">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th>Valor Total</th>
                        <th>Desconto</th>
                        <th>Valor Final</th>
                        <th>Status</th>
                        <th>Ações</th>
                    </tr>
                </thead>
                <tbody id="vendasTableBody">
                    <tr th:each="venda : ${vendas}">
                        <td th:text="${venda.id}"></td>
                        <td>
                            <a th:href="@{/clientes}" th:text="${venda.cliente != null ? venda.cliente.nome : 'N/A'}"></a>
                        </td>
                        <td th:text="${#temporals.format(venda.dataVenda, 'dd/MM/yyyy HH:mm')}"></td>
                        <td th:text="${'R$ ' + #numbers.formatDecimal(venda.valorTotal, 1, 2)}"></td>
                        <td th:text="${'R$ ' + #numbers.formatDecimal(venda.desconto, 1, 2)}"></td>
                        <td th:text="${'R$ ' + #numbers.formatDecimal(venda.valorFinal, 1, 2)}"></td>
                        <td>
                            <span class="badge"
                                  th:classappend="${venda.status == 'APROVADA'} ? 'bg-success' : (${venda.status == 'PENDENTE'} ? 'bg-warning' : (${venda.status == 'CANCELADA'} ? 'bg-danger' : 'bg-info'))"
                                  th:text="${venda.status}"></span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info" th:onclick="'verVenda(' + ${venda.id} + ')'" title="Visualizar">
                                <i class="bi bi-eye"></i>
                            </button>
                            <button class="btn btn-sm btn-warning" th:onclick="'editarVenda(' + ${venda.id} + ')'" title="Editar">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-danger" th:onclick="'deletarVenda(' + ${venda.id} + ')'" title="Excluir">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Modal Cadastrar/Editar Venda -->
    <div class="modal fade" id="modalVenda" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nova Venda</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formVenda">
                        <input type="hidden" id="vendaId" name="id">
                        
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Cliente *</label>
                                <select class="form-select" name="cliente.id" required>
                                    <option value="">Selecione um cliente</option>
                                    <!-- Carregar via AJAX ou Thymeleaf -->
                                </select>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Forma de Pagamento *</label>
                                <select class="form-select" name="formaPagamento" required>
                                    <option value="DINHEIRO">Dinheiro</option>
                                    <option value="CARTAO_CREDITO">Cartão de Crédito</option>
                                    <option value="CARTAO_DEBITO">Cartão de Débito</option>
                                    <option value="PIX">PIX</option>
                                    <option value="BOLETO">Boleto</option>
                                </select>
                            </div>
                        </div>
                        
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Valor Total *</label>
                                <input type="number" class="form-control" name="valorTotal" step="0.01" required>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Desconto</label>
                                <input type="number" class="form-control" name="desconto" step="0.01" value="0.00">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Valor Final *</label>
                                <input type="number" class="form-control" name="valorFinal" step="0.01" required readonly>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status">
                                <option value="PENDENTE">Pendente</option>
                                <option value="APROVADA">Aprovada</option>
                                <option value="CANCELADA">Cancelada</option>
                                <option value="ENTREGUE">Entregue</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary" onclick="salvarVenda()">
                        <i class="bi bi-check-lg"></i> Salvar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script th:inline="javascript">
        /*<![CDATA[*/
        
        // Carregar clientes no select
        window.addEventListener('DOMContentLoaded', function() {
            fetch('/api/clientes')
            .then(response => response.json())
            .then(clientes => {
                const select = document.querySelector('[name="cliente.id"]');
                clientes.forEach(cliente => {
                    const option = document.createElement('option');
                    option.value = cliente.id;
                    option.textContent = cliente.nome;
                    select.appendChild(option);
                });
            });
        });

        // Calcular valor final automaticamente
        document.querySelector('[name="valorTotal"]').addEventListener('input', calcularValorFinal);
        document.querySelector('[name="desconto"]').addEventListener('input', calcularValorFinal);

        function calcularValorFinal() {
            const valorTotal = parseFloat(document.querySelector('[name="valorTotal"]').value) || 0;
            const desconto = parseFloat(document.querySelector('[name="desconto"]').value) || 0;
            const valorFinal = valorTotal - desconto;
            document.querySelector('[name="valorFinal"]').value = valorFinal.toFixed(2);
        }

        function salvarVenda() {
            const form = document.getElementById('formVenda');
            const formData = new FormData(form);
            const data = Object.fromEntries(formData);
            
            // Converter cliente.id para objeto cliente
            if (data['cliente.id']) {
                data.cliente = { id: parseInt(data['cliente.id']) };
                delete data['cliente.id'];
            }
            
            if (!data.id) delete data.id;
            
            const method = data.id ? 'PUT' : 'POST';
            const url = data.id ? `/api/vendas/${data.id}` : '/api/vendas';

            fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            })
            .then(response => {
                if (!response.ok) throw new Error('Erro ao salvar venda');
                return response.json();
            })
            .then(() => {
                alert('Venda salva com sucesso!');
                location.reload();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao salvar venda.');
            });
        }

        function deletarVenda(id) {
            if (confirm('Deseja realmente deletar esta venda?')) {
                fetch(`/api/vendas/${id}`, { method: 'DELETE' })
                .then(response => {
                    if (response.ok) {
                        alert('Venda deletada com sucesso!');
                        location.reload();
                    } else {
                        throw new Error('Erro ao deletar venda');
                    }
                })
                .catch(error => {
                    console.error('Erro:', error);
                    alert('Erro ao deletar venda.');
                });
            }
        }

        function verVenda(id) {
            fetch(`/api/vendas/${id}`)
            .then(response => response.json())
            .then(venda => {
                const clienteNome = venda.cliente ? venda.cliente.nome : 'N/A';
                alert(`Venda #${venda.id}\nCliente: ${clienteNome}\nValor Final: R$ ${venda.valorFinal.toFixed(2)}\nStatus: ${venda.status}`);
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao buscar venda.');
            });
        }

        function editarVenda(id) {
            fetch(`/api/vendas/${id}`)
            .then(response => response.json())
            .then(venda => {
                document.querySelector('[name="id"]').value = venda.id;
                document.querySelector('[name="cliente.id"]').value = venda.cliente ? venda.cliente.id : '';
                document.querySelector('[name="formaPagamento"]').value = venda.formaPagamento;
                document.querySelector('[name="valorTotal"]').value = venda.valorTotal;
                document.querySelector('[name="desconto"]').value = venda.desconto;
                document.querySelector('[name="valorFinal"]').value = venda.valorFinal;
                document.querySelector('[name="status"]').value = venda.status;
                
                document.querySelector('.modal-title').textContent = 'Editar Venda';
                
                const modal = new bootstrap.Modal(document.getElementById('modalVenda'));
                modal.show();
            })
            .catch(error => {
                console.error('Erro:', error);
                alert('Erro ao buscar venda.');
            });
        }

        function filtrarVendas() {
            const dataInicio = document.getElementById('dataInicio').value;
            const dataFim = document.getElementById('dataFim').value;
            const statusFilter = document.getElementById('filterStatus').value;
            const rows = document.querySelectorAll('#vendasTableBody tr');
            
            rows.forEach(row => {
                const dataVenda = row.cells[2].textContent;
                const status = row.querySelector('.badge').textContent.trim();
                
                let matchesDate = true;
                if (dataInicio || dataFim) {
                    // Implementar lógica de filtro de data
                    matchesDate = true; // Simplificado
                }
                
                const matchesStatus = !statusFilter || status === statusFilter;
                
                if (matchesDate && matchesStatus) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        document.getElementById('filterStatus').addEventListener('change', filtrarVendas);

        document.getElementById('modalVenda').addEventListener('hidden.bs.modal', function () {
            document.getElementById('formVenda').reset();
            document.querySelector('.modal-title').textContent = 'Nova Venda';
            document.querySelector('[name="id"]').value = '';
        });
        
        /*]]>*/
    </script>
</div>
</html>